#version 460
// KawPow / ProgPoW search shader -- RDNA3 (gfx11) optimized Vulkan compute.
//
// Mirrors the validated CPU reference (rdna3_kawpow/reference.py) exactly:
//   * keccak_f800 with header(LE) | nonce | tail; seed read big-endian (bswap).
//   * fill_mix (KISS99), the per-period progPowLoop (injected below), digest
//     reduction, and the final keccak.
// RDNA3 specifics:
//   * pipeline forces subgroupSize == 32 (native wave32) via
//     VK_EXT_subgroup_size_control, so a 32-wide subgroup holds exactly two
//     16-lane KawPow hash groups.
//   * cross-lane exchange uses subgroupShuffle (registers, no LDS, no barrier)
//     instead of the GCN-era shared-memory + barrier pattern.
//
// Host injects, by text substitution, the per-epoch #defines, the generated
// progPowLoop() for the current period, and the variant-specific keccak fills.

#extension GL_KHR_shader_subgroup_basic   : require
#extension GL_KHR_shader_subgroup_shuffle : require

#define uint32_t uint        // the generated progPowLoop uses uint32_t
#define PROGPOW_LANES        16
#define PROGPOW_REGS         32
#define PROGPOW_CACHE_WORDS  4096
#define PROGPOW_CNT_DAG      64
#define PROGPOW_DAG_LOADS    4
#define FNV_PRIME            0x01000193u
#define FNV_OFFSET_BASIS     0x811c9dc5u

__DEFINES__

// Workgroup size is a specialization constant (set by host to e.g. 128).
layout(local_size_x_id = 0) in;

struct dag_t { uint s[PROGPOW_DAG_LOADS]; };

layout(std430, binding = 0) readonly buffer HeaderBuf { uint g_header[8]; };
layout(std430, binding = 1) readonly buffer DagBuf    { uint g_dag[]; };   // flat: dag_t row r => g_dag[r*4 + i]
layout(std430, binding = 2) buffer OutBuf {
    uint  count;
    uint  hashCount;
    uint  abort;
    uint  pad;
    // result slots: [gid, mix0..mix7] x MAX_OUTPUTS
    uint  results[];
} g_out;

layout(push_constant) uniform Push {
    uvec2 start_nonce;   // (lo, hi)
    uvec2 target;        // (lo, hi) upper 64 bits of boundary
} pc;

shared uint c_dag[PROGPOW_CACHE_WORDS];

// --- helpers (match reference semantics) ---
uint ROTL32(uint x, uint n) { n &= 31u; return (n == 0u) ? x : ((x << n) | (x >> (32u - n))); }
uint ROTR32(uint x, uint n) { n &= 31u; return (n == 0u) ? x : ((x >> n) | (x << (32u - n))); }
uint mul_hi(uint a, uint b) { umulExtended(a, b, a, b); return a; }   // a receives msb
uint clz(uint x)            { return (x == 0u) ? 32u : uint(31 - findMSB(x)); }
uint popcount(uint x)       { return uint(bitCount(x)); }
uint bswap32(uint x) {
    return ((x >> 24) & 0x000000ffu) | ((x >> 8) & 0x0000ff00u)
         | ((x << 8) & 0x00ff0000u) | ((x << 24) & 0xff000000u);
}

// keccak-f800 round constants
const uint keccakf_rndc[24] = uint[24](
    0x00000001u,0x00008082u,0x0000808au,0x80008000u,0x0000808bu,0x80000001u,
    0x80008081u,0x00008009u,0x0000008au,0x00000088u,0x80008009u,0x8000000au,
    0x8000808bu,0x0000008bu,0x00008089u,0x00008003u,0x00008002u,0x00000080u,
    0x0000800au,0x8000000au,0x80008081u,0x00008080u,0x80000001u,0x80008008u);
const uint keccakf_rotc[24] = uint[24](
    1u,3u,6u,10u,15u,21u,28u,36u,45u,55u,2u,14u,27u,41u,56u,8u,25u,43u,62u,18u,39u,61u,20u,44u);
const uint keccakf_piln[24] = uint[24](
    10u,7u,11u,17u,18u,3u,5u,16u,8u,21u,24u,4u,15u,23u,19u,13u,12u,2u,20u,14u,22u,9u,6u,1u);

void keccak_f800(inout uint st[25]) {
    for (int r = 0; r < 22; r++) {
        uint bc[5];
        for (int i = 0; i < 5; i++)
            bc[i] = st[i] ^ st[i+5] ^ st[i+10] ^ st[i+15] ^ st[i+20];
        for (int i = 0; i < 5; i++) {
            uint t = bc[(i+4)%5] ^ ROTL32(bc[(i+1)%5], 1u);
            for (int j = 0; j < 25; j += 5) st[j+i] ^= t;
        }
        uint t = st[1];
        for (int i = 0; i < 24; i++) {
            uint j = keccakf_piln[i];
            bc[0] = st[j];
            st[j] = ROTL32(t, keccakf_rotc[i]);
            t = bc[0];
        }
        for (int j = 0; j < 25; j += 5) {
            uint g[5];
            for (int i = 0; i < 5; i++) g[i] = st[j+i];
            for (int i = 0; i < 5; i++) st[j+i] ^= (~g[(i+1)%5]) & g[(i+2)%5];
        }
        st[0] ^= keccakf_rndc[r];
    }
}

// KISS99
struct kiss99_t { uint z, w, jsr, jcong; };
uint kiss99(inout kiss99_t st) {
    st.z = 36969u * (st.z & 65535u) + (st.z >> 16);
    st.w = 18000u * (st.w & 65535u) + (st.w >> 16);
    uint MWC = (st.z << 16) + st.w;
    st.jsr ^= (st.jsr << 17);
    st.jsr ^= (st.jsr >> 13);
    st.jsr ^= (st.jsr << 5);
    st.jcong = 69069u * st.jcong + 1234567u;
    return (MWC ^ st.jcong) + st.jsr;
}
uint fnv1a(inout uint h, uint d) { h = (h ^ d) * FNV_PRIME; return h; }

void fill_mix(uint seed0, uint seed1, uint lane_id, out uint mix[PROGPOW_REGS]) {
    uint fnv_hash = FNV_OFFSET_BASIS;
    kiss99_t st;
    st.z = fnv1a(fnv_hash, seed0);
    st.w = fnv1a(fnv_hash, seed1);
    st.jsr = fnv1a(fnv_hash, lane_id);
    st.jcong = fnv1a(fnv_hash, lane_id);
    for (int i = 0; i < PROGPOW_REGS; i++) mix[i] = kiss99(st);
}

// ------ injected per-period inner loop ------
__PROGPOW_LOOP__

void main() {
    uint gid = gl_GlobalInvocationID.x;
    uint lid = gl_LocalInvocationID.x;
    uint lane_id = gl_SubgroupInvocationID & (PROGPOW_LANES - 1u);
    uint sg_base = gl_SubgroupInvocationID & ~(PROGPOW_LANES - 1u);

    // nonce = start_nonce + gid (64-bit add via uvec2)
    uint nlo = pc.start_nonce.x + gid;
    uint nhi = pc.start_nonce.y + ((nlo < pc.start_nonce.x) ? 1u : 0u);

    // Cooperatively preload the cache into LDS.
    for (uint w = lid * PROGPOW_DAG_LOADS; w < PROGPOW_CACHE_WORDS; w += gl_WorkGroupSize.x * PROGPOW_DAG_LOADS) {
        uint row = w / PROGPOW_DAG_LOADS;
        for (uint i = 0u; i < PROGPOW_DAG_LOADS; i++)
            c_dag[w + i] = g_dag[row * PROGPOW_DAG_LOADS + i];
    }
    barrier();

    // Initial keccak -> state2 (this invocation's own nonce).
    uint state2[8];
    {
        uint st[25];
        for (int i = 0; i < 8; i++) st[i] = g_header[i];
        st[8] = nlo; st[9] = nhi;
        for (int i = 10; i < 25; i++) st[i] = 0u;   // vanilla tail (zeros)
        __TAIL_INIT__                               // kawpow overrides st[10..24] = RAVENCOIN
        keccak_f800(st);
        for (int i = 0; i < 8; i++) state2[i] = st[i];
    }

    uint digest[8];
    for (uint h = 0u; h < PROGPOW_LANES; h++) {
        // Broadcast lane h's state2; seed derivation is variant-specific
        // (kawpow: direct; vanilla 0.9.2: big-endian read). Matches reference.py.
        uint s0 = subgroupShuffle(state2[0], sg_base + h);
        uint s1 = subgroupShuffle(state2[1], sg_base + h);
        __SEED_DERIVE__

        uint mix[PROGPOW_REGS];
        fill_mix(seed0, seed1, lane_id, mix);

        for (uint l = 0u; l < PROGPOW_CNT_DAG; l++)
            progPowLoop(l, mix, lane_id, sg_base, false);

        uint digest_lane = FNV_OFFSET_BASIS;
        for (int i = 0; i < PROGPOW_REGS; i++) fnv1a(digest_lane, mix[i]);

        uint dtmp[8];
        for (int i = 0; i < 8; i++) dtmp[i] = FNV_OFFSET_BASIS;
        for (uint i = 0u; i < PROGPOW_LANES; i += 8u)
            for (uint j = 0u; j < 8u; j++) {
                uint v = subgroupShuffle(digest_lane, sg_base + i + j);
                fnv1a(dtmp[j], v);
            }
        if (h == lane_id)
            for (int i = 0; i < 8; i++) digest[i] = dtmp[i];
    }

    // Final keccak -> 64-bit result (big-endian read). The injected fill lays out
    // the whole state per variant:
    //   vanilla: header(8) then seed(2) then digest(8) then zero(7)
    //   kawpow:  state2(8) then digest(8) then RAVENCOIN(9)
    uint result_hi, result_lo;
    {
        uint st[25];
        for (int i = 0; i < 25; i++) st[i] = 0u;
        __FINAL_FILL__
        keccak_f800(st);
        result_hi = bswap32(st[0]);
        result_lo = bswap32(st[1]);
    }

    atomicAdd(g_out.hashCount, 1u);

    // result <= target  (64-bit compare)
    bool ok = (result_hi < pc.target.y) ||
              (result_hi == pc.target.y && result_lo <= pc.target.x);
    if (ok) {
        uint slot = atomicAdd(g_out.count, 1u);
        if (slot < MAX_OUTPUTS) {
            uint base = slot * 9u;
            g_out.results[base] = gid;
            for (uint i = 0u; i < 8u; i++) g_out.results[base + 1u + i] = digest[i];
        }
        atomicAdd(g_out.abort, 1u);
    }
}
